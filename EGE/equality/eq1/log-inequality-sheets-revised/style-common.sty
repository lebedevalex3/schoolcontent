\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{style-common}[2026/07/11 Common logarithmic inequality handout style v2]

% =================================================
% Язык и шрифты
% =================================================
\RequirePackage{fontspec}
\RequirePackage{polyglossia}
\setdefaultlanguage{russian}

% Используем стандартные системные шрифты macOS и подключаем файлы явно,
% чтобы сборка XeLaTeX не зависела от пользовательской папки Fonts.
\setmainfont{Times New Roman.ttf}[
  Path=/System/Library/Fonts/Supplemental/,
  BoldFont={Times New Roman Bold.ttf},
  ItalicFont={Times New Roman Italic.ttf},
  BoldItalicFont={Times New Roman Bold Italic.ttf}
]
\setsansfont{Arial.ttf}[
  Path=/System/Library/Fonts/Supplemental/,
  BoldFont={Arial Bold.ttf},
  ItalicFont={Arial Italic.ttf},
  BoldItalicFont={Arial Bold Italic.ttf}
]
\setmonofont{Courier New.ttf}[
  Path=/System/Library/Fonts/Supplemental/,
  BoldFont={Courier New Bold.ttf},
  ItalicFont={Courier New Italic.ttf},
  BoldItalicFont={Courier New Bold Italic.ttf}
]

% Явно сообщаем Polyglossia, какие семейства использовать для русского.
\newfontfamily\cyrillicfont{Times New Roman.ttf}[
  Path=/System/Library/Fonts/Supplemental/,
  BoldFont={Times New Roman Bold.ttf},
  ItalicFont={Times New Roman Italic.ttf},
  BoldItalicFont={Times New Roman Bold Italic.ttf}
]
\newfontfamily\cyrillicfontsf{Arial.ttf}[
  Path=/System/Library/Fonts/Supplemental/,
  BoldFont={Arial Bold.ttf},
  ItalicFont={Arial Italic.ttf},
  BoldItalicFont={Arial Bold Italic.ttf}
]
\newfontfamily\cyrillicfonttt{Courier New.ttf}[
  Path=/System/Library/Fonts/Supplemental/,
  BoldFont={Courier New Bold.ttf},
  ItalicFont={Courier New Italic.ttf},
  BoldItalicFont={Courier New Bold Italic.ttf}
]

