\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{style-common}[2026/07/12 Common geometry problem-pack style]

% =================================================
% Язык и шрифты
% =================================================
\RequirePackage{fontspec}
\RequirePackage{polyglossia}
\setdefaultlanguage{russian}

\IfFontExistsTF{Times New Roman}
  {\setmainfont{Times New Roman}}
  {\setmainfont{Tinos}}

\IfFontExistsTF{Arial}
  {\setsansfont{Arial}}
  {\setsansfont{Arimo}}

\IfFontExistsTF{Consolas}
  {\setmonofont{Consolas}}
  {\setmonofont{DejaVu Sans Mono}}

% =================================================
% Страница
% =================================================
\RequirePackage[
  a4paper,
  left=22mm,
  right=22mm,
  top=23mm,
  bottom=23mm,
  headheight=26pt,
  headsep=7mm
]{geometry}

% =================================================
% Пакеты
% =================================================
\RequirePackage{amsmath,amssymb}
\RequirePackage{booktabs}
\RequirePackage{tabularx}
\RequirePackage{array}
\RequirePackage{enumitem}
\RequirePackage{xcolor}
\RequirePackage[most]{tcolorbox}
\RequirePackage{fancyhdr}
\RequirePackage{microtype}
\RequirePackage{hyperref}
\RequirePackage{needspace}
\RequirePackage{titlesec}
\RequirePackage{graphicx}
\RequirePackage{tikz}
\RequirePackage{xparse}
\RequirePackage{ifthen}
\usetikzlibrary{
  arrows.meta,
  calc,
  angles,
  quotes,
  patterns.meta,
  decorations.pathreplacing,
  positioning
}

% =================================================
% Общая типографика
% =================================================
\setlength{\parindent}{0pt}
\setlength{\parskip}{0.62em}
\linespread{1.12}

\setlist[itemize]{
  leftmargin=1.65em,
  itemsep=0.42em,
  topsep=0.4em,
  parsep=0pt,
  partopsep=0pt
}

\setlist[enumerate]{
  leftmargin=2em,
  itemsep=0.48em,
  topsep=0.42em,
  parsep=0pt,
  partopsep=0pt
}

\newcommand{\mainfontsize}{%
  \fontsize{13.2pt}{16.4pt}\selectfont
}

% =================================================
% Заголовки
% =================================================
\newcommand{\SectionFont}{%
  \Large\bfseries\sffamily\color{Primary}%
  \raggedright\hyphenpenalty=10000\exhyphenpenalty=10000
}

\newcommand{\SubsectionFont}{%
  \large\bfseries\sffamily\color{Secondary}%
  \raggedright\hyphenpenalty=10000\exhyphenpenalty=10000
}

\titleformat{\section}
  {\SectionFont}
  {\thesection.}
  {0.65em}
  {}

\titleformat{\subsection}
  {\SubsectionFont}
  {}
  {0pt}
  {}

\titleformat{\subsubsection}
  {\normalsize\bfseries\sffamily\raggedright}
  {}
  {0pt}
  {}

\titlespacing*{\section}{0pt}{1.7em}{0.72em}
\titlespacing*{\subsection}{0pt}{1.2em}{0.5em}
\titlespacing*{\subsubsection}{0pt}{0.9em}{0.35em}

% =================================================
% Колонтитулы
% =================================================
\providecommand{\DocumentCourse}{Геометрия. 7 класс}
\providecommand{\DocumentTopic}{Скрытый треугольник и окружность}

\pagestyle{fancy}
\fancyhf{}
\fancyhead[L]{\footnotesize\sffamily\color{GrayText}\DocumentCourse}
\fancyhead[R]{\footnotesize\sffamily\color{GrayText}\DocumentTopic}
\fancyfoot[C]{\small\color{GrayText}\thepage}
\renewcommand{\headrulewidth}{0.35pt}
\renewcommand{\headrule}{%
  \hbox to\headwidth{\color{GrayLine}\leaders\hrule height \headrulewidth\hfill}%
}

\fancypagestyle{firstpage}{
  \fancyhf{}
  \fancyfoot[C]{\small\color{GrayText}\thepage}
  \renewcommand{\headrulewidth}{0pt}
}

% =================================================
% Служебные команды комплекта
% =================================================
\newcommand{\tasklabel}[1]{%
  \tikz[baseline=(n.base)]\node[
    circle,
    fill=Primary,
    text=white,
    font=\bfseries\sffamily\small,
    inner sep=1.4pt,
    minimum size=5.6mm
  ] (n) {#1};%
}

\newcommand{\teacherlabel}{%
  \tikz[baseline=(n.base)]\node[
    rounded corners=1mm,
    fill=Accent,
    text=white,
    font=\bfseries\sffamily\scriptsize,
    inner xsep=2.2mm,
    inner ysep=0.7mm
  ] (n) {ДЛЯ УЧИТЕЛЯ};%
}

\newcommand{\checkbox}{\tikz[baseline=-0.6ex]\draw[line width=0.45pt] (0,0) rectangle (0.23,0.23);}

\newcommand{\answerline}[1][1]{%
  \par\vspace{0.15em}%
  \foreach \i in {1,...,#1}{%
    \noindent\color{GrayLine}\rule{\linewidth}{0.45pt}\par\vspace{0.62em}%
  }%
}

\newcommand{\shortanswer}[1]{%
  \hfill\textcolor{GrayText}{\rule{#1}{0.45pt}}%
}

\newcommand{\solutiongap}[1][3.2cm]{%
  \par\vspace{0.3em}\noindent
  \begin{tikzpicture}
    \draw[draw=GrayLine] (0,0) rectangle (\linewidth,#1);
  \end{tikzpicture}
}

\newcommand{\logicarrow}{\;\Longrightarrow\;}

\newcommand{\packtitle}[2]{%
  \begin{center}
    {\fontsize{24}{28}\selectfont\bfseries\sffamily\color{Primary}#1}

    \vspace{0.28em}

    {\large\sffamily\color{GrayText}#2}
  \end{center}
  \vspace{0.25em}
}

\newcommand{\studentnameblock}{%
  \begin{tabularx}{\linewidth}{@{}X@{\hspace{1.2cm}}p{42mm}@{}}
    Имя и фамилия: \hrulefill & Дата: \hrulefill
  \end{tabularx}
  \vspace{0.35em}
}

% =================================================
% Базовые стили рисунков. Конкретные цвета задаются
% в style-color.sty и style-bw.sty.
% =================================================
\tikzset{
  geo label/.style={font=\small},
  geo angle label/.style={font=\small},
  geo tiny label/.style={font=\scriptsize},
  geo right angle/.style={draw=Secondary,thin,angle radius=4mm},
  geo angle/.style={draw=Accent,thin,angle radius=7mm},
  geo equal mark/.style={draw=Secondary,line width=0.55pt},
  geo point/.style={circle,fill=Primary,draw=Primary,inner sep=1.45pt},
  geo center point/.style={circle,fill=Accent,draw=Accent,inner sep=1.7pt},
  geo main/.style={draw=Primary,line width=0.72pt},
  geo strong/.style={draw=Primary,line width=1.05pt},
  geo auxiliary/.style={draw=Secondary,dashed,line width=0.55pt},
  geo radius/.style={draw=Secondary,line width=0.65pt},
  geo circle/.style={draw=Secondary,line width=0.78pt},
  geo highlight/.style={draw=Accent,line width=1.05pt},
  geo construction/.style={draw=GrayText,dashed,line width=0.5pt}
}
