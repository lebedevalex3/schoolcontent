\renewcommand{\tasklabel}[1]{%
  \tikz[baseline=(n.base)]\node[circle,draw=black,fill=white,text=black,
    font=\bfseries\sffamily\small,inner sep=1.2pt,minimum size=5.5mm] (n) {#1};%
}
\renewcommand{\teacherlabel}{%
  \tikz[baseline=(n.base)]\node[rounded corners=0.7mm,draw=black,fill=white,text=black,
    font=\bfseries\sffamily\scriptsize,inner xsep=2mm,inner ysep=0.5mm] (n) {ДЛЯ УЧИТЕЛЯ};%
}

