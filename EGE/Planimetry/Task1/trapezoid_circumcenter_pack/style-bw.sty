% =================================================
\newtcolorbox{definitionbox}[1][Определение]{
	enhanced,
	breakable,
	colback=white,
	colframe=black,
	boxrule=0.7pt,
	arc=1.2mm,
	left=4mm,
	right=4mm,
	top=3mm,
	bottom=2.7mm,
	title={#1},
	fonttitle=\bfseries\sffamily,
	coltitle=black,
	colbacktitle=white,
	attach boxed title to top left={xshift=4mm,yshift=-2mm},
	boxed title style={
		colback=white,
		colframe=black,
		boxrule=0.7pt,
		arc=0.8mm,
		left=2.5mm,
		right=2.5mm,
		top=0.8mm,
		bottom=0.8mm
	},
	before skip=1.1em,
	after skip=1.1em
}

