% =================================================
% Служебные команды
% =================================================
\newcommand{\homeworktitle}[2]{%
  \begin{center}
    {\fontsize{24pt}{28pt}\selectfont\bfseries\sffamily\color{Primary} #1\par}
    \vspace{0.35em}
    {\large\sffamily\color{Secondary} #2\par}
  \end{center}
  \vspace{0.55em}
}

\newcommand{\studentline}{%
  \noindent
  \begin{tabularx}{\textwidth}{@{}X@{\hspace{1.2em}}p{0.28\textwidth}@{}}
    \textbf{Фамилия, имя:}\ \hrulefill &
    \textbf{Дата:}\ \hrulefill
  \end{tabularx}
}

\newcommand{\answerspace}[1]{%
  \par\vspace{0.3em}%
  \begin{tcolorbox}[
    enhanced,
    colback=white,
    colframe=GrayLine,
    boxrule=0.45pt,
    arc=1mm,
    height=#1,
    left=3mm,right=3mm,top=2mm,bottom=2mm,
    borderline west={1.6pt}{0pt}{Primary},
    before skip=0.45em,after skip=0.45em
  ]
  \end{tcolorbox}%
}

\newcommand{\tasklabel}[1]{%
  \tikz[baseline=(n.base)]{%
    \node[
      circle,
      fill=Primary,
      text=white,
      minimum size=7mm,
      inner sep=0pt,
      font=\bfseries\sffamily\small
    ] (n) {#1};%
  }%
}

\newcommand{\teacheronlylabel}{%
  \tikz[baseline=(n.base)]{%
    \node[
      rounded corners=1mm,
      fill=Accent,
      text=white,
      inner xsep=4pt,
      inner ysep=1.5pt,
      font=\bfseries\sffamily\footnotesize
    ] (n) {для учителя};%
  }%
}


\newcommand{\solutionmap}{%
  \par\vspace{0.35em}
  \begin{tcolorbox}[
    enhanced,
    colback=white,
    colframe=GrayLine,
    boxrule=0.45pt,
    arc=1mm,
    left=3.5mm,right=3.5mm,top=2.5mm,bottom=2.5mm,
    borderline west={1.6pt}{0pt}{Primary},
    before skip=0.45em,after skip=0.55em
  ]
    \renewcommand{\arraystretch}{1.45}
    \begin{tabularx}{\linewidth}{@{}>{\bfseries\sffamily}p{0.34\linewidth}X@{}}
      Условие двух нулей: & \hrulefill \\
      Нули числителя: & \hrulefill \\
      Проверка знаменателя: & \hrulefill \\
      Ответ: & \hrulefill
    \end{tabularx}
  \end{tcolorbox}%
}

\newcommand{\shortanswerline}{%
  \par\vspace{0.35em}
  \noindent\textbf{Ответ:}\ \hrulefill\par
}

