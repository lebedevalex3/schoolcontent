\newtcolorbox{routebox}[1][Маршрут решения]{
  enhanced,
  breakable,
  colback=SecondaryLight,
  colframe=Secondary,
  boxrule=0.75pt,
  arc=2mm,
  left=4.5mm,right=4.5mm,top=3mm,bottom=3mm,
  title={#1},
  fonttitle=\bfseries\sffamily,
  coltitle=white,
  colbacktitle=Secondary,
  attach boxed title to top left={xshift=5mm,yshift=-2.3mm},
  boxed title style={
    colback=Secondary,colframe=Secondary,boxrule=0pt,arc=1.3mm,
    left=3mm,right=3mm,top=1.2mm,bottom=1.2mm
  },
  before skip=0.9em,after skip=0.9em
}

