\newcommand{\structuredsolutionmap}{%
  \par\vspace{0.35em}
  \begin{tcolorbox}[
    enhanced,colback=white,colframe=GrayLine,boxrule=0.45pt,arc=1mm,
    left=3.5mm,right=3.5mm,top=2.2mm,bottom=2.2mm,
    borderline west={1.6pt}{0pt}{Primary},
    before skip=0.4em,after skip=0.45em
  ]
    \renewcommand{\arraystretch}{1.38}
    \begin{tabularx}{\linewidth}{@{}>{\bfseries\sffamily}p{0.34\linewidth}X@{}}
      Ноль на ветви \(x\ge0\): & \hrulefill \\
      Ноль на ветви \(x<0\): & \hrulefill \\
      Условие двух нулей: & \hrulefill \\
      \(D(x_1)\): & \hrulefill \\
      \(D(x_2)\): & \hrulefill \\
      Исключаемые параметры: & \hrulefill \\
      Ответ: & \hrulefill
    \end{tabularx}
  \end{tcolorbox}%
}

