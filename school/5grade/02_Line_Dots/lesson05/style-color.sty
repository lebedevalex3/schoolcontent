\newtcolorbox{problembox}[1][Задача]{
  enhanced,
  breakable,
  colback=PrimaryLight,
  colframe=Primary,
  boxrule=0.8pt,
  arc=2mm,
  left=5mm,right=5mm,top=4mm,bottom=3.5mm,
  title={#1},
  fonttitle=\bfseries\sffamily,
  coltitle=white,
  colbacktitle=Primary,
  attach boxed title to top left={xshift=5mm,yshift=-2.5mm},
  boxed title style={
    colback=Primary,colframe=Primary,boxrule=0pt,arc=1.5mm,
    left=3mm,right=3mm,top=1.5mm,bottom=1.5mm
  },
  before skip=1.05em,after skip=1.05em
}

