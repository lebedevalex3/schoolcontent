\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{style-color}[2026/07/11 Color geometry handout style v1]

% =================================================
% Палитра
% =================================================
\definecolor{Primary}{HTML}{2F5D8A}
\definecolor{PrimaryLight}{HTML}{EEF4FA}
\definecolor{Secondary}{HTML}{3E7C72}
\definecolor{SecondaryLight}{HTML}{EEF7F5}
\definecolor{Accent}{HTML}{A35F20}
\definecolor{AccentLight}{HTML}{FFF5E9}
\definecolor{GrayText}{HTML}{666666}
\definecolor{GrayLine}{HTML}{D9DEE4}
\definecolor{GrayLight}{HTML}{F6F7F9}
\colorlet{TableHeader}{PrimaryLight}

\hypersetup{
  colorlinks=true,
  linkcolor=Primary,
  urlcolor=Primary
}

% =================================================
% TikZ: логика задачи
% =================================================
\tikzset{
  par logic condition/.style={
    draw=Primary,
    fill=PrimaryLight,
    rounded corners=2mm,
    line width=0.8pt,
    minimum height=15mm,
    text width=5.6cm,
    align=center,
    font=\small\sffamily
  },
  par logic result/.style={
    draw=Secondary,
    fill=SecondaryLight,
    rounded corners=2mm,
    line width=0.9pt,
    minimum height=15mm,
    text width=6.2cm,
    align=center,
    font=\small\bfseries\sffamily
  },
  par logic arrow/.style={
    -{Stealth[length=3mm]},
    line width=1pt,
    draw=Accent
  },
  par logic plus/.style={font=\Large\bfseries\sffamily,text=Accent}
}

% =================================================
% TikZ: графический метод
% =================================================
\tikzset{
  par axis/.style={-{Stealth[length=2.6mm]},draw=GrayText,line width=0.55pt},
  par graph/.style={draw=Primary,line width=1.45pt},
  par level negative/.style={draw=GrayText,line width=0.95pt,dashed},
  par level zero/.style={draw=Accent,line width=1.2pt},
  par level positive/.style={draw=Secondary,line width=1.2pt,dash pattern=on 6pt off 2.5pt},
  par guide/.style={draw=GrayLine,line width=0.65pt,densely dotted},
  par intersection/.style={circle,fill=Secondary,draw=white,line width=0.4pt,inner sep=2.2pt},
  par origin intersection/.style={circle,fill=Accent,draw=white,line width=0.4pt,inner sep=2.2pt},
  par graph heading/.style={font=\bfseries\sffamily,text=Primary},
  par graph caption/.style={font=\small\sffamily,text=GrayText,align=center},
  par graph label/.style={font=\small,text=GrayText},
  par level label/.style={font=\small\bfseries\sffamily},
  par branch label/.style={font=\small\sffamily,text=Primary,fill=white,inner sep=1.5pt}
}

% =================================================
% TikZ: числовая прямая ответа
% =================================================
\tikzset{
  par number base/.style={-{Stealth[length=2.5mm]},draw=GrayText,thin},
  par number accepted/.style={draw=Secondary,very thick},
  par number excluded/.style={circle,draw=Accent,fill=white,line width=0.95pt,inner sep=2.15pt},
  par number tick/.style={draw=GrayText,thin},
  par number label/.style={font=\small,text=GrayText},
  par number note/.style={font=\footnotesize\sffamily,text=Accent,align=center}
}

