# ==================================================
# Сгенерированные файлы LaTeX
# Исходные .tex-файлы НЕ игнорируются
# ==================================================

# Основной результат компиляции
*.pdf
*.pptx

# Вспомогательные файлы LaTeX
*.aux
*.log
*.out
*.toc
*.lof
*.lot
*.fls
*.fdb_latexmk
*.synctex
*.synctex.gz
*.xdv
*.dvi
*.ps

# Библиография
*.bbl
*.bcf
*.blg
*.run.xml

# Индексы и глоссарии
*.idx
*.ilg
*.ind
*.ist
*.acn
*.acr
*.alg
*.glg
*.glo
*.gls
*.glsdefs

# Beamer
*.nav
*.snm
*.vrb

# Временные файлы
*.tmp
*.bak
*.backup
*.sav
*.swp
*.lock
*~

# ==================================================
# Архивы и служебный мусор
# ==================================================

# Архивы исходных паков (тяжёлые, собираются из .tex)
*.zip
*.tar
*.tar.gz
*.7z
/tmp

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
