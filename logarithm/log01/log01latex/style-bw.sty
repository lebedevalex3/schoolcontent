\newtcolorbox{problembox}[1][Задача]{
  enhanced,breakable,colback=white,colframe=black,boxrule=0.75pt,arc=1.2mm,
  left=4.5mm,right=4.5mm,top=3.5mm,bottom=3mm,
  title={#1},fonttitle=\bfseries\sffamily,coltitle=black,colbacktitle=white,
  attach boxed title to top left={xshift=4mm,yshift=-2mm},
  boxed title style={
    colback=white,colframe=black,boxrule=0.7pt,arc=0.8mm,
    left=2.5mm,right=2.5mm,top=0.8mm,bottom=0.8mm
