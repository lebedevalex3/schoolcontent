\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{style-bw}[2026/07/11 Black-and-white parameter handout style v3]

% =================================================
% Палитра
% =================================================
\colorlet{Primary}{black}
\colorlet{Secondary}{black}
\colorlet{Accent}{black}
\colorlet{GrayText}{black}
\colorlet{GrayLine}{black}
\colorlet{PrimaryLight}{white}
\colorlet{SecondaryLight}{white}
\colorlet{AccentLight}{white}
\colorlet{GrayLight}{white}
\colorlet{TableHeader}{white}

\hypersetup{hidelinks}

% =================================================
% TikZ: логика задачи
% =================================================
\tikzset{
  par logic condition/.style={
    draw=black,fill=white,rounded corners=1mm,line width=0.7pt,
    minimum height=15mm,text width=5.6cm,align=center,font=\small\sffamily
  },
  par logic result/.style={
    draw=black,fill=white,rounded corners=1mm,double,double distance=0.6pt,
    line width=0.7pt,minimum height=15mm,text width=6.2cm,
    align=center,font=\small\bfseries\sffamily
  },
  par logic arrow/.style={-{Stealth[length=3mm]},line width=0.9pt,draw=black},
  par logic plus/.style={font=\Large\bfseries\sffamily,text=black}
}

% =================================================
% TikZ: графический метод
% =================================================
\tikzset{
  par axis/.style={-{Stealth[length=2.6mm]},draw=black,line width=0.5pt},
  par graph/.style={draw=black,line width=1.45pt},
  par level negative/.style={draw=black,line width=0.85pt,dashed},
  par level zero/.style={draw=black,line width=1.05pt,densely dotted},
  par level positive/.style={draw=black,line width=1.05pt,dash pattern=on 7pt off 2pt},
  par guide/.style={draw=black,line width=0.55pt,densely dotted},
  par intersection/.style={circle,fill=black,draw=black,inner sep=2.1pt},
  par origin intersection/.style={circle,fill=black,draw=black,inner sep=2.1pt},
  par graph heading/.style={font=\bfseries\sffamily,text=black},
  par graph caption/.style={font=\small\sffamily,text=black,align=center},
  par graph label/.style={font=\small,text=black},
  par level label/.style={font=\small\bfseries\sffamily,text=black},
  par branch label/.style={font=\small\sffamily,text=black,fill=white,inner sep=1.5pt}
}

% =================================================
% TikZ: числовая прямая ответа
% =================================================
\tikzset{
  par number base/.style={-{Stealth[length=2.5mm]},draw=black,thin},
  par number accepted/.style={draw=black,very thick},
  par number excluded/.style={circle,draw=black,fill=white,line width=0.95pt,inner sep=2.15pt},
  par number tick/.style={draw=black,thin},
  par number label/.style={font=\small,text=black},
  par number note/.style={font=\footnotesize\sffamily,text=black,align=center}
}

