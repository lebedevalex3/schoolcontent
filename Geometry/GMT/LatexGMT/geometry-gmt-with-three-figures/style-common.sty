\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{style-common}[2026/07/11 Common geometry handout style]

% =================================================
% Общая часть оформления
% =================================================

% -------------------------------------------------
% Язык и шрифты
% -------------------------------------------------
\RequirePackage{fontspec}
\RequirePackage{polyglossia}
\setdefaultlanguage{russian}

\IfFontExistsTF{Times New Roman}
	{\setmainfont{Times New Roman}}
	{\setmainfont{Tinos}}

\IfFontExistsTF{Arial}
	{\setsansfont{Arial}}
	{\setsansfont{Arimo}}

\IfFontExistsTF{Consolas}
	{\setmonofont{Consolas}}
	{\setmonofont{DejaVu Sans Mono}}

% -------------------------------------------------
% Геометрия страницы
% -------------------------------------------------
\RequirePackage[
	a4paper,
	left=25mm,
	right=25mm,
	top=23mm,
	bottom=25mm,
	headheight=18pt,
	headsep=8mm
]{geometry}

% -------------------------------------------------
% Математика, таблицы и списки
% -------------------------------------------------
\RequirePackage{amsmath,amssymb}
\RequirePackage{booktabs}
\RequirePackage{tabularx}
\RequirePackage{array}
\RequirePackage{enumitem}

% -------------------------------------------------
% Служебные пакеты
% -------------------------------------------------
\RequirePackage{xcolor}
\RequirePackage[most]{tcolorbox}
\RequirePackage{fancyhdr}
\RequirePackage{microtype}
\RequirePackage{hyperref}
\RequirePackage{needspace}
\RequirePackage{titlesec}
\RequirePackage{graphicx}
\RequirePackage{tikz}
\usetikzlibrary{arrows.meta,calc,patterns.meta}

% -------------------------------------------------
% Общая типографика
% -------------------------------------------------
\setlength{\parindent}{0pt}
\setlength{\parskip}{0.8em}
\linespread{1.16}

\setlist[itemize]{
	leftmargin=1.7em,
	itemsep=0.55em,
	topsep=0.5em,
	parsep=0pt,
	partopsep=0pt
}

\setlist[enumerate]{
	leftmargin=2em,
	itemsep=0.65em,
	topsep=0.55em,
	parsep=0pt,
	partopsep=0pt
}

\newcommand{\mainfontsize}{%
	\fontsize{13.5pt}{17pt}\selectfont
}

% -------------------------------------------------
% Заголовки
% Цвета задаются в style-color.sty или style-bw.sty.
% -------------------------------------------------
\newcommand{\SectionFont}{%
	\Large\bfseries\sffamily\color{Primary}%
	\raggedright\hyphenpenalty=10000\exhyphenpenalty=10000
}

\newcommand{\SubsectionFont}{%
	\large\bfseries\sffamily\color{Secondary}%
	\raggedright\hyphenpenalty=10000\exhyphenpenalty=10000
}

\titleformat{\section}
	{\SectionFont}
	{\thesection.}
	{0.65em}
	{}

\titleformat{\subsection}
	{\SubsectionFont}
	{}
	{0pt}
	{}

\titleformat{\subsubsection}
	{\normalsize\bfseries\sffamily\raggedright}
	{}
	{0pt}
	{}

\titlespacing*{\section}{0pt}{2.2em}{0.9em}
\titlespacing*{\subsection}{0pt}{1.5em}{0.6em}
\titlespacing*{\subsubsection}{0pt}{1.1em}{0.4em}

% -------------------------------------------------
% Колонтитулы
% -------------------------------------------------
\pagestyle{fancy}
\fancyhf{}

\fancyhead[L]{%
	\footnotesize\sffamily\color{GrayText} Геометрия. 7 класс
}

\fancyhead[R]{%
	\footnotesize\sffamily\color{GrayText} Геометрическое место точек
}

\fancyfoot[C]{%
	\small\color{GrayText}\thepage
}

\renewcommand{\headrulewidth}{0.35pt}

\renewcommand{\headrule}{%
	\hbox to\headwidth{%
		\color{GrayLine}\leaders\hrule height \headrulewidth\hfill
	}
}

\fancypagestyle{firstpage}{
	\fancyhf{}
	\fancyfoot[C]{\small\color{GrayText}\thepage}
	\renewcommand{\headrulewidth}{0pt}
}
