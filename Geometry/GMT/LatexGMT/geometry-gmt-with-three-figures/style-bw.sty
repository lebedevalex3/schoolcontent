\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{style-bw}[2026/07/11 Black-and-white geometry handout style]

% =================================================
% Палитра
% =================================================
\colorlet{Primary}{black}
\colorlet{Secondary}{black}
\colorlet{Accent}{black}
\colorlet{GrayText}{black}
\colorlet{GrayLine}{black}

\hypersetup{hidelinks}

% =================================================
% TikZ: рисунок «от точек к окружности»
% =================================================
\tikzset{
	gmt point/.style={circle,fill=black,draw=black,inner sep=1.6pt},
	gmt center/.style={circle,fill=black,draw=black,inner sep=2pt},
	gmt radius/.style={draw=black,thin},
	gmt auxiliary/.style={draw=black!55,dashed,thin},
	gmt main circle/.style={draw=black,very thick},
	gmt arrow/.style={-{Stealth[length=3mm]},very thick,draw=black},
	gmt heading/.style={font=\bfseries\sffamily,text=black},
	gmt caption/.style={align=center,text=black},
	gmt transition text/.style={align=center,font=\small\sffamily,text=black},
	gmt point label/.style={text=black},
	gmt center label/.style={text=black},
	gmt radius label/.style={text=black}
}

% =================================================
% TikZ: сравнение OM<R, OM=R, OM<=R, OM>R
% =================================================
\tikzset{
	gmt distance point/.style={circle,fill=black,draw=black,inner sep=1.5pt},
	gmt distance center/.style={circle,fill=black,draw=black,inner sep=1.7pt},
	gmt distance boundary/.style={draw=black,thick},
	gmt distance excluded boundary/.style={draw=black,thick,dashed},
	gmt distance radius/.style={draw=black,thin},
	gmt distance inside fill/.style={
		pattern={Lines[angle=45,distance=4pt,line width=0.35pt]},
		pattern color=black
	},
	gmt distance outside fill/.style={
		pattern={Lines[angle=-45,distance=4pt,line width=0.35pt]},
		pattern color=black
	},
	gmt distance heading/.style={font=\bfseries\sffamily,text=black},
	gmt distance caption/.style={align=center,text=black},
	gmt distance point label/.style={text=black},
	gmt distance center label/.style={text=black}
}



% =================================================
% TikZ: пропущенные и лишние точки
% =================================================
\tikzset{
	gmt correct point/.style={circle,fill=black,draw=black,inner sep=1.4pt},
	gmt error center/.style={circle,fill=black,draw=black,inner sep=1.6pt},
	gmt correct boundary/.style={draw=black,thick},
	gmt helper boundary/.style={draw=black!55,dashed,thin},
	gmt highlighted error point/.style={
		circle,
		draw=black,
		fill=white,
		line width=0.65pt,
		inner sep=1.7pt
	},
	gmt error radius/.style={draw=black,thin},
	gmt extra region/.style={
		pattern={
			Dots[
				distance=5pt,
				radius=0.4pt
			]
		},
		pattern color=black
	},
	gmt error heading/.style={font=\bfseries\sffamily,text=black},
	gmt success heading/.style={font=\bfseries\sffamily,text=black},
	gmt error caption/.style={align=center,text=black},
	gmt success caption/.style={align=center,text=black},
	gmt error callout arrow/.style={-{Stealth[length=2.5mm]},draw=black,thin},
	gmt error callout text/.style={align=left,text=black},
	gmt error center label/.style={text=black},
	gmt error point label/.style={text=black}
}

% =================================================
% Ключевые теоретические блоки
% =================================================
\newtcolorbox{definitionbox}[1][Определение]{
	enhanced,
	breakable,
	colback=white,
	colframe=black,
	boxrule=0.7pt,
	arc=1.2mm,
	left=4mm,
	right=4mm,
	top=3mm,
	bottom=2.7mm,
	title={#1},
	fonttitle=\bfseries\sffamily,
	coltitle=black,
	colbacktitle=white,
	attach boxed title to top left={xshift=4mm,yshift=-2mm},
	boxed title style={
		colback=white,
		colframe=black,
		boxrule=0.7pt,
		arc=0.8mm,
		left=2.5mm,
		right=2.5mm,
		top=0.8mm,
		bottom=0.8mm
	},
	before skip=1.1em,
	after skip=1.1em
}

\newtcolorbox{propertybox}[1][Основное свойство]{
	enhanced,
	breakable,
